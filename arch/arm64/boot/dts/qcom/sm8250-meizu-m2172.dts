&i2c4 {
	status = "okay";

	aw882xx_r: speaker-amp@34 {
		status = "okay";
		compatible = "awinic,aw882xx_smartpa";
		reg = <0x34>;
		monitor-flag = <0x01>;

		reset-gpio = <&tlmm 116 GPIO_ACTIVE_HIGH>;
		//irq-gpio = <&tlmm 117 0x2008>;

		sound-channel = <0>;
		sync-flag = <0x00>;

		#sound-dai-cells = <1>;
		aw-cali-mode = "aw_misc";
	};

	aw882xx_l: speaker-amp@35 {
		status = "okay";
		compatible = "awinic,aw882xx_smartpa";
		reg = <0x35>;
		monitor-flag = <0x01>;

		reset-gpio = <&tlmm 115 GPIO_ACTIVE_HIGH>;
		// irq-gpio = <&tlmm 118 0x2008>;

		sound-channel = <1>;
		sync-flag = <0x00>;

		#sound-dai-cells = <1>;
		aw-cali-mode = "aw_misc";
	};
};

&i2c15 {
	//clock-frequency = <100000>;
	status = "okay";

	typec-mux@43 {
		compatible = "fcs,fsa4480";
		reg = <0x43>;

		vcc-supply = <&vreg_bob>;

		mode-switch;
		orientation-switch;

		port {
			fsa4480_sbu_mux: endpoint {
				remote-endpoint = <&pm8150b_typec_sbu_out>;
			};
		};
	};

	nq@64 {
		compatible = "rtc6226";
		reg = <0x64>;
		fmint-gpio = <&tlmm 0x33 GPIO_ACTIVE_HIGH>;
		rtc6226,vio-supply = <&vreg_s4a_1p8>;
		// rtc6226,vio-supply-voltage = <0x1b7740 0x1b7740>;
		rtc6226,vdd-supply = <&vreg_bob>;
		// rtc6226,vdd-supply-voltage = <0x324b00 0x324b00>;

	};
};

&i2c16 {
	status = "disabled";

	pm8008: pmic@8 {
		compatible = "qcom,pm8008";
		reg = <0x8>;

		interrupts-extended = <&tlmm 84 IRQ_TYPE_EDGE_RISING>;
		reset-gpios = <&tlmm 0x33 GPIO_ACTIVE_LOW>;

		vdd-l1-l2-supply = <&vreg_s8c_1p35>;
		vdd-l3-l4-supply = <&vreg_bob>;
		vdd-l5-supply = <&vreg_bob>;
		vdd-l6-supply = <&vreg_bob>;
		vdd-l7-supply = <&vreg_bob>;

		pinctrl-names = "default";
		pinctrl-0 = <&pm8008_int_default>, <&pm8008_reset_n_default>;

		gpio-controller;
		#gpio-cells = <2>;
		gpio-ranges = <&pm8008 0 0 2>;

		interrupt-controller;
		#interrupt-cells = <2>;

		#thermal-sensor-cells = <0>;

		regulators {
			vreg_l1p: ldo1 {
				regulator-name = "vreg_l1p";
				regulator-min-microvolt = <1056000>;
				regulator-max-microvolt = <1056000>;
			};

			vreg_l2p: ldo2 {
				regulator-name = "vreg_l2p";
				regulator-min-microvolt = <1104000>;
				regulator-max-microvolt = <1104000>;
			};

			vreg_l3p: ldo3 {
				regulator-name = "vreg_l3p";
				regulator-min-microvolt = <2704000>;
				regulator-max-microvolt = <2704000>;
			};

			vreg_l4p: ldo4 {
				regulator-name = "vreg_l4p";
				regulator-min-microvolt = <2800000>;
				regulator-max-microvolt = <2800000>;
			};

			vreg_l5p: ldo5 {
				regulator-name = "vreg_l5p";
				regulator-min-microvolt = <2800000>;
				regulator-max-microvolt = <2800000>;
			};

			vreg_l6p: ldo6 {
				regulator-name = "vreg_l6p";
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <1800000>;
			};

			vreg_l7p: ldo7 {
				regulator-name = "vreg_l7p";
				regulator-min-microvolt = <2800000>;
				regulator-max-microvolt = <2900000>;
			};
		};
	};
};

&spi2 {
	status = "disabled";
	pinctrl-names = "default";
	pinctrl-0 = <&qup_spi2_data_clk>;
	clock-frequency = <50000000>;

	irled@0 {
		compatible = "ir-spi-led";
		reg = <0x0>;

		spi-max-frequency = <19200000>;
		power-supply = <&vph_pwr>;
		duty-cycle = /bits/ 8 <60>;
		led-active-low;
	};
};

&qup_spi4_cs_gpio {
	drive-strength = <6>;
	bias-disable;
};

&qup_spi4_data_clk {
	drive-strength = <6>;
	bias-disable;
};

&i2c13  {
	status = "okay";
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&qupv3_se13_i2c_active>;
	pinctrl-1 = <&qupv3_se13_i2c_sleep>;
	qcom,i2c-touch-active = "focaltech,fts_ts";
	clock-names = "se", "m-ahb", "s-ahb";
	clocks = <&gcc GCC_QUPV3_WRAP1_S5_CLK &gcc GCC_QUPV3_WRAP_1_S_AHB_CLK &gcc GCC_QUPV3_WRAP_2_M_AHB_CLK>;

	touchscreen@38 {
		compatible = "focaltech,fts_ts";
		reg = <0x38>;
		interrupt-parent = <&tlmm>;
		interrupts = <39 IRQ_TYPE_EDGE_FALLING>;
		vdd-supply = <&vreg_l13a_3p3>;
		vcc_i2c-supply = <&vreg_l1c_1p8>;

		pinctrl-0 = <&ts_active>;
		pinctrl-1 = <&ts_int_suspend &ts_reset_suspend>;
		pinctrl-2 = <&ts_release>;
		pinctrl-names = "pmx_ts_active", "pmx_ts_suspend", "pmx_ts_release";

		focaltech,irq-gpio = <&tlmm 39 IRQ_TYPE_EDGE_FALLING>;
		focaltech,reset-gpio = <&tlmm 38 GPIO_ACTIVE_LOW>;

		focaltech,max-touch-number = <10>;
		focaltech,display-coords = <0 0 1080 2400>;

		//panel = <&panel>;
	};
};

&pcie0 {
	// perst-gpios = <&tlmm 79 GPIO_ACTIVE_HIGH>;
	// wake-gpios = <&tlmm 81 GPIO_ACTIVE_HIGH>;
	// vddpe-3v3-supply = <&vreg_l13a_3p3>;
	// vdda-supply = <&vreg_l12a_1p8>;
	status = "okay";
};

&pcie0_phy {
	vdda-phy-supply = <&vreg_l5a_0p88>;
	vdda-pll-supply = <&vreg_l9a_1p2>;
	status = "okay";
};

&pcieport0 {
	status = "okay";

	wifi@0 {
		compatible = "pci17cb,1101";
		reg = <0x10000 0x0 0x0 0x0 0x0>;
		status = "okay";

		vddrfacmn-supply = <&vreg_pmu_rfa_cmn>;
		vddaon-supply = <&vreg_pmu_aon_0p59>;
		vddwlcx-supply = <&vreg_pmu_wlcx_0p8>;
		vddwlmx-supply = <&vreg_pmu_wlmx_0p85>;
		vddrfa0p8-supply = <&vreg_pmu_rfa_0p8>;
		vddrfa1p2-supply = <&vreg_pmu_rfa_1p2>;
		vddrfa1p7-supply = <&vreg_pmu_rfa_1p7>;
		vddpcie0p9-supply = <&vreg_pmu_pcie_0p9>;
		vddpcie1p8-supply = <&vreg_pmu_pcie_1p8>;
		// vddpe-3v3-supply = <&vreg_l13a_3p3>;
		// vdda-supply = <&vreg_l12a_1p8>;
	};
};

&pm8150_gpios {
	vol_up_n: vol-up-n-state {
		pins = "gpio6";
		function = "normal";
		power-source = <1>;
		input-enable;
		bias-pull-up;
	};
};

&pm8150b_vbus {
	regulator-min-microamp = <500000>;
	regulator-max-microamp = <3000000>;
	status = "okay";
};

&pm8150b_typec {
	status = "okay";

	vdd-pdphy-supply = <&vreg_l2a_3p1>;

	connector {
		compatible = "usb-c-connector";

		power-role = "dual";
		data-role = "dual";
		try-power-role = "sink";
		self-powered;

		op-sink-microwatt = <33000000>;

		source-pdos = <PDO_FIXED(5000, 3000,
					  PDO_FIXED_DUAL_ROLE |
					  PDO_FIXED_USB_COMM |
					  PDO_FIXED_DATA_SWAP)>;

		sink-pdos = <PDO_FIXED(5000, 3000,
					   PDO_FIXED_DUAL_ROLE |
					   PDO_FIXED_USB_COMM |
					   PDO_FIXED_DATA_SWAP)
					   PDO_VAR(5000, 9000, 3500)>;

		ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;
				pm8150b_hs_in: endpoint {
					remote-endpoint = <&usb_1_dwc3_hs_out>;
				};
			};

			port@1 {
				reg = <1>;

				pm8150b_typec_sbu_out: endpoint {
					remote-endpoint = <&fsa4480_sbu_mux>;
				};
			};
		};
	};
};

&pm8150b_fg {
	status = "okay";
	monitored-battery = <&battery>;
	power-supplies = <&pm8150b_charger>;
};

&pm8150b_charger {
	status = "okay";
	monitored-battery = <&battery>;
};

&pm8150l_flash {
	status = "okay";

	led-0 {
		function = LED_FUNCTION_FLASH;
		color = <LED_COLOR_ID_WHITE>;
		led-sources = <1>;
		led-max-microamp = <300000>;
		flash-max-microamp = <1000000>;
		flash-max-timeout-us = <1280000>;
	};
};

&pon_pwrkey {
	status = "okay";
};

&pon_resin {
	linux,code = <KEY_VOLUMEDOWN>;
	status = "okay";
};

&qupv3_id_0 {
	status = "okay";
};

&qupv3_id_1 {
	status = "okay";
};

&qupv3_id_2 {
	reg = <0x0 0x008c0000 0x0 0x2000>;
	status = "okay";
};

&q6afedai {
	dai@56 {
		// reg = <TERTIARY_TDM_RX_0>;
		// qcom,tdm-sync-mode = <0>;
		// qcom,tdm-sync-src = <1>;
		// qcom,tdm-data-out = <0>;
		// qcom,tdm-invert-sync = <1>;
		// qcom,tdm-data-delay = <1>;
		// qcom,tdm-data-align = <0>;
		reg = <TERTIARY_TDM_RX_0>;
		qcom,tdm-sync-mode = <1>;     /* Sync mode: 1=secondary (for AW88261) */
		qcom,tdm-sync-src = <1>;      /* Sync source: 1=internal */
		qcom,tdm-data-out = <0>;      /* Data out: 0=enabled */
		qcom,tdm-invert-sync = <0>;   /* Don't invert sync for AW88261 */
		qcom,tdm-data-delay = <1>;    /* 1-bit data delay for proper alignment */
		qcom,tdm-data-align = <0>;    /* No special alignment needed */
		// qcom,sd-lines = <0 1>;
	};
};

&q6asmdai {
	status = "okay";
	dai@0 {
		reg = <MSM_FRONTEND_DAI_MULTIMEDIA1>;
	};

	dai@1 {
		reg = <MSM_FRONTEND_DAI_MULTIMEDIA2>;
	};

	dai@2 {
		reg = <MSM_FRONTEND_DAI_MULTIMEDIA3>;
	};

	dai@3 {
		reg = <MSM_FRONTEND_DAI_MULTIMEDIA4>;
	};

	dai@4 {
		reg = <MSM_FRONTEND_DAI_MULTIMEDIA5>;
	};

	dai@5 {
		reg = <MSM_FRONTEND_DAI_MULTIMEDIA6>;
	};

};

&vamacro {
	status = "okay";
};

&lpass_tlmm {
	status = "okay";
};

&sound {
	compatible = "qcom,sm8250-sndcard";
	model = "meizu-m2172-sndcard";
	pinctrl-names = "default";
	pinctrl-0 = <&tert_tdm_active>;
	status = "okay";


	mm1-dai-link {
		link-name = "MultiMedia2";

		cpu {
			sound-dai = <&q6asmdai MSM_FRONTEND_DAI_MULTIMEDIA3>;
		};
	};

	speaker-dai-link {
		link-name = "Tertiary TDM Playback";
		no-pcm;

		cpu {
			sound-dai = <&q6afedai TERTIARY_TDM_RX_0>;
		};

		platform {
			sound-dai = <&q6routing>;
		};

		codec {
			sound-dai = <&aw882xx_r 0>, <&aw882xx_l 0>;
			// sound-dai = <&aw882xx_r 0>;
		};
	};
};

&slpi {
	firmware-name = "qcom/sm8250/meizu/m2172/slpi.mbn";
	status = "okay";
};

&tlmm {
	// reg = <0 0x0f000000 0 0x1000000>;
	gpio-reserved-ranges = <28 4>, <40 4>;
	status = "okay";

	tert_tdm_active: tert-tdm-active-state {
		sck-pins {
			pins = "gpio133";
			function = "mi2s2_sck";
			drive-strength = <8>;
			bias-disable;
			output-high;
		};

		din-pins {
			pins = "gpio134";
			function = "mi2s2_data0";
			drive-strength = <8>;
			bias-disable;
		};

		ws-pins {
			pins = "gpio135";
			function = "mi2s2_ws";
			drive-strength = <8>;
			bias-disable;
			output-high;
		};

		dout-pins {
			pins = "gpio137";
			function = "mi2s2_data1";
			drive-strength = <8>;
			bias-disable;
		};
	};

	bt_en_state: bt-default-state {
		bt-en-pins {
			pins = "gpio21";
			function = "gpio";
			drive-strength = <16>;
			output-low;
			bias-pull-up;
		};
	};

	wlan_en_state: wlan-default-state {
		wlan-en-pins {
			pins = "gpio20";
			function = "gpio";
			drive-strength = <16>;
			output-low;
			bias-pull-up;
		};
	};

	ts_active: ts-active {
		mux {
			pins = "gpio38", "gpio39";
			function = "gpio";
		};

		config {
			pins = "gpio38", "gpio39";
			drive-strength = <8>;
			bias-pull-up;
		};
	};

	ts_release: ts-release {
		mux {
			pins = "gpio38", "gpio39";
			function = "gpio";
		};
		config {
			pins = "gpio38", "gpio39";
			drive-strength = <2>;
			bias-disable;
		};
	};

	ts_int_suspend: ts-int-suspend {
		mux {
			pins = "gpio39";
			function = "gpio";
		};
		config {
			pins = "gpio39";
			drive-strength = <2>;
			bias-pull-down;
		};
	};

	ts_reset_suspend: ts-reset-suspend {
		mux {
			pins = "gpio38";
			function = "gpio";
		};
		config {
			pins = "gpio38";
			drive-strength = <2>;
			bias-pull-down;
		};
	};

	// sde_dsi_active: sde_dsi_active-state {
	// 	pins = "gpio12";
	// 	function = "gpio";
	// 	drive-strength = <8>;
	// 	bias-disable;
	// 	output-high;
	// };

	// sde_dsi_sleep: sde-dsi-sleep-state {
	// 	pins = "gpio12";
	// 	function = "gpio";
	// 	drive-strength = <2>;
	// 	bias-pull-down;
	// 	output-high;
	// };

	sde_dsi_active: sde_dsi_active-state {
		pins = "gpio128";
		function = "gpio";
		drive-strength = <8>;
		bias-disable;
		output-high;
	};

	sde_dsi_sleep: sde-dsi-sleep-state {
		pins = "gpio128";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
		output-high;
	};

	sde_te_active_sleep: sde_te_active-state {
		pins = "gpio66";
		function = "mdp_vsync";
		drive-strength = <2>;
		bias-pull-down;
	};

	sw_ctrl: sw-ctrl-state {
		pins = "gpio124";
		function = "gpio";
		bias-pull-down;
	};

	pm8008_int_default: pm8008-int-default-state {
		pins = "gpio84";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	pm8008_reset_n_default: pm8008-reset-n-default-state {
		pins = "gpio77";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	cam_s5k5e9_default: cam-s5k5e9-default-state {
		rst-pins {
			pins = "gpio92";
			function = "gpio";
			drive-strength = <2>;
			bias-disable;
		};

		mclk1-pins {
			pins = "gpio95";
			function = "cam_mclk";
			drive-strength = <2>;
			bias-disable;
		};
	};

	cam_imx355_default: cam-imx355-default-state {
		rst-pins {
			pins = "gpio78";
			function = "gpio";
			drive-strength = <2>;
			bias-disable;
		};

		mclk2-pins {
			pins = "gpio96";
			function = "cam_mclk";
			drive-strength = <2>;
			bias-disable;
		};
	};

	cam_imx582_default: cam-imx582-default-state {
		rst-pins {
			pins = "gpio93";
			function = "gpio";
			drive-strength = <2>;
			bias-disable;
		};

		mclk0-pins {
			pins = "gpio94";
			function = "cam_mclk";
			drive-strength = <2>;
			bias-disable;
		};
	};

	qupv3_se6_4uart_pins {

		qupv3_se6_default_tx: qupv3_se6_default_tx {

			mux {
				function = "gpio";
				pins = "gpio18";
			};

			config {
				pins = "gpio18";
				drive-strength = <0x02>;
				bias-pull-up;
			};
		};

		qupv3_se6_default_cts: qupv3_se6_default_cts {

			mux {
				function = "gpio";
				pins = "gpio16";
			};

			config {
				pins = "gpio16";
				drive-strength = <0x02>;
				bias-disable;
			};
		};

		qupv3_se6_rts: qupv3_se6_rts {

			mux {
				function = "qup6";
				pins = "gpio17";
			};

			config {
				pins = "gpio17";
				drive-strength = <0x02>;
				bias-pull-down;
			};
		};

		qupv3_se6_tx: qupv3_se6_tx {

			mux {
				function = "qup6";
				pins = "gpio18";
			};

			config {
				pins = "gpio18";
				drive-strength = <0x02>;
				bias-pull-up;
			};
		};

		qupv3_se6_default_rtsrx: qupv3_se6_default_rtsrx {

			mux {
				function = "gpio";
				pins = "gpio17", "gpio19";
			};

			config {
				pins = "gpio17", "gpio19";
				drive-strength = <0x02>;
				bias-pull-down;
			};
		};

		qupv3_se6_ctsrx: qupv3_se6_ctsrx {

			mux {
				function = "qup6";
				pins = "gpio16", "gpio19";
			};

			config {
				pins = "gpio16", "gpio19";
				drive-strength = <0x02>;
				bias-disable;
			};
		};
	};

	qupv3_se13_i2c_sleep: qupv3_se13_i2c_sleep {

		mux {
			function = "gpio";
			pins = "gpio36", "gpio37";
		};

		config {
			pins = "gpio36", "gpio37";
			drive-strength = <0x02>;
			bias-no-pull;
		};
	};

	qupv3_se13_i2c_active: qupv3_se13_i2c_active {

		mux {
			function = "qup13";
			pins = "gpio36", "gpio37";
		};

		config {
			pins = "gpio36", "gpio37";
			drive-strength = <0x02>;
			bias-disable;
		};
	};

};


&uart6 {
	status = "okay";

	bluetooth {
		compatible = "qcom,qca6390-bt";
		// pinctrl-names = "default";
		// pinctrl-0 = <&sw_ctrl>;
		// swctrl-gpios = <&tlmm 124 GPIO_ACTIVE_HIGH>;
		vddrfacmn-supply = <&vreg_pmu_rfa_cmn>;
		vddaon-supply = <&vreg_pmu_aon_0p59>;
		// vddasd-supply = <&vreg_l16a_3p3>;
		vddbtcmx-supply = <&vreg_pmu_btcmx_0p85>;
		vddrfa0p8-supply = <&vreg_pmu_rfa_0p8>;
		vddrfa1p2-supply = <&vreg_pmu_rfa_1p2>;
		vddrfa1p7-supply = <&vreg_pmu_rfa_1p7>;

		firmware-name = "htnv20.bin";
	};

};

&usb_1 {
	/* USB 2.0 only */
	qcom,select-utmi-as-pipe-clk;
	status = "okay";
};

&usb_1_dwc3 {
	dr_mode = "otg";
	usb-role-switch;
	maximum-speed = "high-speed";
	/* Remove USB3 phy */
	phys = <&usb_1_hsphy>;
	phy-names = "usb2-phy";
	status = "okay";
};

&usb_1_dwc3_hs_out {
	remote-endpoint = <&pm8150b_hs_in>;
};

&usb_1_hsphy {
	vdda-pll-supply = <&vreg_l5a_0p88>;
	vdda18-supply = <&vreg_l12a_1p8>;
	vdda33-supply = <&vreg_l2a_3p1>;
	status = "okay";
};

&ufs_mem_hc {
	vcc-supply = <&vreg_l17a_3p0>;
	vcc-max-microamp = <800000>;
	vccq-supply = <&vreg_l6a_1p2>;
	vccq-max-microamp = <800000>;
	vccq2-supply = <&vreg_s4a_1p8>;
	vccq2-max-microamp = <800000>;
	status = "okay";
};

&ufs_mem_phy {
	vdda-phy-supply = <&vreg_l5a_0p88>;
	vdda-pll-supply = <&vreg_l9a_1p2>;
	status = "okay";
};

&venus {
	firmware-name = "qcom/sm8250/meizu/m2172/venus.mbn";
	status = "okay";
};